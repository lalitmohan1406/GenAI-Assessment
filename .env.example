# FinanceOS — environment variable template
# Copy this file to `.env` and fill in the values below.
#   cp .env.example .env
# NEVER commit your real .env — it is gitignored.

# --- Database (required) ---------------------------------------------------
# SQLite file used by Prisma. The default works out of the box; `prisma/dev.db`
# is created/seeded by `npm run db:reset`.
DATABASE_URL="file:./dev.db"

# --- Auth (required) -------------------------------------------------------
# Signs the JWT session cookie. The app will not start without it.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-string"

# --- Claude / Anthropic (optional) -----------------------------------------
# Enables live LLM triage. If left blank, the app runs end-to-end on the
# deterministic rules-based fallback and labels every recommendation as
# "fallback" in the UI — no code changes needed.
ANTHROPIC_API_KEY=""

# Claude model id. Defaults to claude-sonnet-4-5 if unset.
ANTHROPIC_MODEL="claude-sonnet-4-5"
